# 템플릿·작업 폴더 경로는 설정 > 경로 설정에서 저장됩니다 (app/data/worship.db).
# 아래 값은 최초 DB 생성 시에만 참고용으로 읽힙니다.

# 한글 / 템플릿 (선택 — DB에 없을 때만 시드)
# HWP_TEMPLATE_PATH=C:\Users\churchCom\Documents\churchCloud\교회 문서\03 주보\광주새백성교회_주보_2026_메일머지.hwpx
# DAY_PPT_TEMPLATE_PATH=C:\Users\churchCom\Documents\churchCloud\교회 문서\■ PPT\주일낮예배-2026-템플릿.pptx
# HYMN_PPT_DIR=C:\Users\churchCom\Documents\churchCloud\교회 문서\■ PPT\찬송가 PPT
# HYMN_SLIDESHOW_DIR=C:\Users\churchCom\Documents\churchCloud\찬양 자료\찬송가 PPT
# RESPONSIVE_PPT_DIR=C:\Users\churchCom\Documents\churchCloud\교회 문서\■ PPT\교독문 PPT
# RESPONSIVE_SLIDESHOW_DIR=C:\Users\churchCom\Documents\churchCloud\교회 문서\■ PPT\교독문 PPT
# OUTPUT_DIR=app/data/output

# 관리자 로그인 (선택)
# ADMIN_USERNAME=admin
# HTTPS 프록시 뒤에서 쿠키 secure 플래그
# COOKIE_SECURE=false

# 역방향 프록시 (비우면 요청 Host / X-Forwarded-* 헤더로 자동 판별)
PUBLIC_URL=https://worship.newpeoplech.com
TRUST_PROXY_HEADERS=true
# 프록시 서버 IP. 같은 PC의 nginx/caddy면 127.0.0.1, 원격 프록시면 해당 IP 또는 *
FORWARDED_ALLOW_IPS=127.0.0.1
